{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Jade",
  "scopeName": "source.jade",
  "fileTypes": ["jde"],
  "patterns": [
    { "include": "#comment" },
    { "include": "#fstring" },
    { "include": "#string" },
    { "include": "#prompt-deref" },
    { "include": "#function-declaration" },
    { "include": "#type-declaration" },
    { "include": "#keywords" },
    { "include": "#storage-types" },
    { "include": "#constants" },
    { "include": "#numbers" },
    { "include": "#support-functions" },
    { "include": "#closure-params" },
    { "include": "#operators" }
  ],
  "repository": {
    "comment": {
      "name": "comment.line.double-slash.jade",
      "match": "//.*$"
    },

    "fstring": {
      "name": "string.quoted.double.jade",
      "begin": "f\"",
      "end": "\"",
      "patterns": [
        {
          "name": "meta.embedded.line.jade",
          "begin": "\\{",
          "beginCaptures": {
            "0": { "name": "punctuation.section.embedded.begin.jade" }
          },
          "end": "\\}",
          "endCaptures": {
            "0": { "name": "punctuation.section.embedded.end.jade" }
          },
          "patterns": [{ "include": "$self" }]
        },
        {
          "name": "constant.character.escape.jade",
          "match": "\\\\."
        }
      ]
    },

    "string": {
      "name": "string.quoted.double.jade",
      "begin": "\"",
      "end": "\"",
      "patterns": [
        {
          "name": "constant.character.escape.jade",
          "match": "\\\\."
        }
      ]
    },

    "prompt-deref": {
      "comment": "?varname — the ? gets jade-green, the name gets variable coloring",
      "match": "(\\?)([a-zA-Z_][a-zA-Z0-9_]*)",
      "captures": {
        "1": { "name": "keyword.other.prompt.jade" },
        "2": { "name": "variable.other.jade" }
      }
    },

    "function-declaration": {
      "comment": "fn name( — colors fn as keyword and name as function entity",
      "match": "\\b(fn)\\s+([a-zA-Z_][a-zA-Z0-9_]*)\\s*(?=\\()",
      "captures": {
        "1": { "name": "keyword.declaration.jade" },
        "2": { "name": "entity.name.function.jade" }
      }
    },

    "type-declaration": {
      "patterns": [
        {
          "comment": "struct Name / interface Name",
          "match": "\\b(struct|interface)\\s+([A-Za-z_][A-Za-z0-9_]*)",
          "captures": {
            "1": { "name": "keyword.declaration.jade" },
            "2": { "name": "entity.name.type.jade" }
          }
        },
        {
          "comment": "extend Name / extend Name: Interface",
          "match": "\\b(extend)\\s+([A-Za-z_][A-Za-z0-9_]*)(?:\\s*:\\s*([A-Za-z_][A-Za-z0-9_]*))?",
          "captures": {
            "1": { "name": "keyword.declaration.jade" },
            "2": { "name": "entity.name.type.jade" },
            "3": { "name": "entity.other.inherited-class.jade" }
          }
        }
      ]
    },

    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.jade",
          "match": "\\b(if|elif|else|while|for|in|return|try|catch|raise)\\b"
        },
        {
          "name": "keyword.declaration.jade",
          "match": "\\b(let|fn|struct|extend|interface|use)\\b"
        },
        {
          "comment": "prompt keyword — same jade-green scope as ?deref",
          "name": "keyword.other.prompt.jade",
          "match": "\\bprompt\\b"
        },
        {
          "name": "keyword.other.jade",
          "match": "\\bself\\b"
        }
      ]
    },

    "storage-types": {
      "comment": "primitive types used in typed prompts and interface signatures",
      "name": "storage.type.jade",
      "match": "\\b(int|float|bool|str)\\b"
    },

    "constants": {
      "name": "constant.language.boolean.jade",
      "match": "\\b(true|false)\\b"
    },

    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.float.jade",
          "match": "\\b\\d+\\.\\d+\\b"
        },
        {
          "name": "constant.numeric.integer.jade",
          "match": "\\b\\d+\\b"
        }
      ]
    },

    "support-functions": {
      "name": "support.function.builtin.jade",
      "match": "\\b(print|len)\\b(?=\\s*\\()"
    },

    "closure-params": {
      "comment": "Matches |x, y| closure params. Lookbehind excludes alnum/]/)/| to avoid bitwise |. Lookahead requires the content starts with a letter (not a space), filtering out bitwise `a | b | c` chains.",
      "begin": "(?<![a-zA-Z0-9_])\\|(?=[a-zA-Z_][a-zA-Z0-9_,\\s]*\\|)",
      "beginCaptures": {
        "0": { "name": "punctuation.definition.parameters.begin.jade" }
      },
      "end": "\\|",
      "endCaptures": {
        "0": { "name": "punctuation.definition.parameters.end.jade" }
      },
      "patterns": [
        {
          "name": "variable.parameter.jade",
          "match": "[a-zA-Z_][a-zA-Z0-9_]*"
        }
      ]
    },

    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.pipe.jade",
          "match": "\\|>"
        },
        {
          "name": "keyword.operator.arrow.jade",
          "match": "->"
        },
        {
          "name": "keyword.operator.logical.jade",
          "match": "&&|\\|\\||!"
        },
        {
          "name": "keyword.operator.bitwise.jade",
          "match": "<<|>>|[&|^~]"
        },
        {
          "name": "keyword.operator.comparison.jade",
          "match": "==|!=|<=|>=|<|>"
        },
        {
          "name": "keyword.operator.arithmetic.jade",
          "match": "[+\\-*/%]"
        },
        {
          "name": "keyword.operator.assignment.jade",
          "match": "(?<![=!<>])=(?!=)"
        }
      ]
    }
  }
}
